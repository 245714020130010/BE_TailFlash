# Backend runtime secrets (example values only)
# Copy to .env locally or configure in your secret manager / CI variables.

# Database
DB_URL=jdbc:mysql://localhost:3306/tailflash_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=tailflash_user
DB_PASSWORD=replace_me

# JWT
JWT_SECRET=replace_with_long_random_secret_at_least_32_chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# SMTP / Reset password email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=replace_me
MAIL_PASSWORD=replace_me
MAIL_FROM_EMAIL=no-reply@tailflash.local
MAIL_FROM_NAME=TailFlash Support
PASSWORD_RESET_URL=http://localhost:3000/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

# Google OAuth
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me

# VNPay
VNPAY_TMN_CODE=replace_me
VNPAY_HASH_SECRET=replace_me

# Cloudinary
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me
